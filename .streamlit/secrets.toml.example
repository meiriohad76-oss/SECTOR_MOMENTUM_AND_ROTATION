# Copy this file to .streamlit/secrets.toml on the Pi (and on Windows for local dev)
# and fill in your real API keys. The real secrets.toml is gitignored.
#
# Get a free FRED API key at: https://fred.stlouisfed.org/docs/api/api_key.html

FRED_API_KEY = "your-32-char-fred-api-key-here"

# Optional historical OHLCV provider.
# yfinance remains the free default. Use "auto" to prefer Massive when MASSIVE_API_KEY is set.
# Keep TLS verification enabled unless a local certificate store blocks manual smoke testing.
OHLCV_PROVIDER = "yfinance"
MASSIVE_VERIFY_SSL = "true"

# Optional Pillar 7 ETF primary-flow provider.
# Keep FLOW_STUB_MODE unset/true for neutral local and production behavior.
# Set FLOW_STUB_MODE=false only after configuring Massive and per-ticker source URLs.
MASSIVE_API_KEY = ""
FLOW_STUB_MODE = "true"
ETF_PRIMARY_FLOW_URL_SOXX = "https://issuer.example/path/to/soxx-primary-flow.csv"

# Optional Pillar 7 provider switches.
# Keep each unset/true until its feed is configured and tested.
# MASSIVE_TRADES_STUB_MODE=false enables Massive /v3/trades block-trade ratio.
# FINRA_ATS_STUB_MODE=false enables FINRA ATS weekly dark-pool percentage.
# FINRA_SHORT_INTEREST_STUB_MODE=false enables FINRA consolidated short-interest delta.
# SEC_13F_STUB_MODE=false enables configured SEC 13F data-set parsing.
MASSIVE_TRADES_STUB_MODE = "true"
FINRA_ATS_STUB_MODE = "true"
FINRA_SHORT_INTEREST_STUB_MODE = "true"
SEC_13F_STUB_MODE = "true"

# Optional SEC 13F configuration. SEC requests need a descriptive User-Agent.
SEC_USER_AGENT = "sector-dashboard your-email@example.com"
SEC_13F_DATA_URL = "https://www.sec.gov/files/structureddata/data/form-13f-data-sets/YYYYqQ_form13f.zip"
SEC_13F_CUSIP_XLK = "81369Y100"

# Optional state-transition alerts. Leave blank/unset to disable network calls.
TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""
SLACK_WEBHOOK_URL = ""
# Validate Telegram/Slack without printing tokens or webhook URLs:
#   ./.venv/bin/python scripts/smoke_telegram_slack_alerts.py --dry-run
# Send a synthetic Telegram/Slack test only after setting the target secret(s):
#   ./.venv/bin/python scripts/smoke_telegram_slack_alerts.py --send-test
# Validate Discord/Mattermost without printing URLs:
#   ./.venv/bin/python scripts/smoke_discord_mattermost_webhooks.py --dry-run
# Send a synthetic provider test only after setting the target webhook URL(s):
#   ./.venv/bin/python scripts/smoke_discord_mattermost_webhooks.py --send-test
DISCORD_WEBHOOK_URL = ""
MATTERMOST_WEBHOOK_URL = ""

# Optional LOW severity daily email digest. Schedule scripts/send_email_digest.py
# for 08:00 ET on the Pi. Leave blank/unset to disable network calls.
SMTP_HOST = ""
SMTP_PORT = "587"
SMTP_USERNAME = ""
SMTP_PASSWORD = ""
SMTP_STARTTLS = "true"
EMAIL_DIGEST_FROM = ""
EMAIL_DIGEST_TO = ""

# Optional PWA Web Push configuration. Validate without sending:
#   ./.venv/bin/python scripts/send_pwa_push_notifications.py --dry-run
VAPID_PRIVATE_KEY = ""
VAPID_PUBLIC_KEY = ""
VAPID_CLAIM_EMAIL = ""
PWA_DASHBOARD_URL = ""

# Optional read-only broker readiness diagnostics for B-131.
# These values are checked by scripts/check_broker_config.py but are not used
# to connect, sync holdings, or place orders.
BROKER_PROVIDER = "none"
ALPACA_API_KEY_ID = ""
ALPACA_API_SECRET_KEY = ""
ALPACA_BASE_URL = "https://paper-api.alpaca.markets"
IBKR_HOST = ""
IBKR_PORT = ""
IBKR_CLIENT_ID = ""

# Optional structured JSON log shipping. Local JSONL logs are written to
# data/logs/app.jsonl by default. Leave LOG_SHIP_URL blank/unset to disable
# network shipping.
LOG_LEVEL = "INFO"
STRUCTURED_LOG_PATH = ""
LOG_SHIP_URL = ""
LOG_SHIP_TOKEN = ""
